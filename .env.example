# Copiá este archivo a ".env.local" y completá tu clave.
# Conseguí tu API key en https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Opcional: modelo a usar. Por defecto: claude-opus-4-8 (el más capaz).
# Para abaratar costos podés usar claude-sonnet-4-6 o claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8
