# Copiá este archivo a ".env.local" y completá los valores.
# Conseguí tu API key en https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Opcional: modelo a usar. Por defecto: claude-opus-4-8 (el más capaz).
# Para abaratar costos podés usar claude-sonnet-4-6 o claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8

# Opcional — Importar CVs desde Gmail (avisos de ZonaJobs).
# Casilla donde llegan los CVs + una "Contraseña de aplicación" de Google
# (requiere Verificación en 2 pasos activada en esa cuenta).
GMAIL_USER=empleadosloeke@gmail.com
GMAIL_APP_PASSWORD=
